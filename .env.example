# SumoPod AI (OpenAI-compatible)
AI_KEY=your_sumopod_key

# Supabase (shared across projects)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_KEY=eyJ...your_service_key

# Resend (email delivery for magic links)
RESEND_API_KEY=re_your_resend_key

# Trakteer Webhook
TRAKTEER_WEBHOOK_TOKEN=your_webhook_token
